stores/

# Test coverage
coverage/
.nyc_output/
reports/coverage/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Local AI assistant config (machine-specific)
.claude/

# Build
dist/
build/

# Temporary
tmp/
temp/
*.tmp

# Solution-brief build: keep the source scripts, drop generated images
# (node_modules is already ignored above)
reports/brief/*.png
reports/brief/*.svg
